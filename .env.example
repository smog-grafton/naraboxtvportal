APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Set true to require email verification after register and SMS OTP for phone login.
AUTH_REQUIRE_VERIFICATION_CODES=false

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
DB_QUEUE_RETRY_AFTER=21660
# Run long imports on dedicated workers, e.g.
# php artisan queue:work database --queue=tele-ob-imports,contabo-imports --timeout=21600 --tries=1

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

FRONTEND_URL=http://localhost:3000

# Public API clients (Next.js + mobile): when APP_API_KEY_ENABLED=true, send this value
# as header X-API-KEY on every /api/v1/* request. Must match NEXT_PUBLIC_API_KEY (web)
# and EXPO_PUBLIC_API_KEY (app). Not stored in the database.
APP_API_KEY=
APP_API_KEY_ENABLED=true
# APP_API_KEY_HEADER=X-API-KEY

# Flutterwave
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_ENCRYPTION_KEY=
FLW_ENV=live
FLW_CURRENCY=UGX

# ioTec
IOTEC_CLIENT_ID=
IOTEC_CLIENT_SECRET=
IOTEC_GRANT_TYPE=client_credentials
IOTEC_ID_BASE_URL=https://id.iotec.io
IOTEC_PAY_BASE_URL=https://pay.iotec.io
IOTEC_WALLET_ID=

# PawaPay
PAWAPAY_ENV=sandbox
PAWAPAY_BASE_URL=https://api.sandbox.pawapay.io
PAWAPAY_API_TOKEN=
PAWAPAY_VERIFY_CALLBACK_SIGNATURE=false

# Push notifications
PUSH_PROVIDER=log
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=
ONESIGNAL_API_BASE_URL=https://api.onesignal.com

# CDN Media Server (naraboxtv-cdn)
# Keep this aligned with the CDN app, not the portal APP_URL above.
CDN_API_BASE_URL=http://127.0.0.1:8001
CDN_API_TOKEN=
CDN_IMPORT_MODE_DEFAULT=now
CDN_CONNECT_TIMEOUT=30
CDN_TIMEOUT=300
CDN_RETRY_TIMES=2
CDN_RETRY_SLEEP_MS=800
CDN_FORCE_IP_RESOLVE=v4
CDN_INGEST_SECRET=
CDN_INGEST_ENDPOINT=/api/ingest/asset-source-upload
PORTAL_FETCH_PROXY_TOKEN=
CDN_PYTHON_WORKER_ENABLED=false
CDN_PYTHON_WORKER_HOSTS=mobifliks.info,mobifliks.com
CDN_USE_PLAYBACK_MANIFEST=true
CDN_REMOTE_PLAYBACK_MANIFEST_LOOKUP=false
CDN_HLS_READINESS_CHECK_ENABLED=true
CDN_HLS_READINESS_CHECK_ON_PLAYBACK=false
CDN_HLS_READINESS_TTL_MINUTES=30
CDN_HLS_READINESS_CONNECT_TIMEOUT=3
CDN_HLS_READINESS_TIMEOUT=8
CDN_HLS_AUTO_DEACTIVATE_UNREADY=true
CDN_HLS_AUTO_QUEUE_MISSING=false

# NBX Engine (new CDN processing VPS)
NBX_ENGINE_ENABLED=false
NBX_ENGINE_BASE_URL=
NBX_ENGINE_API_KEY=
NBX_ENGINE_WEBHOOK_SECRET=
NBX_ENGINE_CALLBACK_URL="${APP_URL}/api/nbx/webhook"
NBX_WEBHOOK_TOLERANCE_SECONDS=300
NBX_ENGINE_TIMEOUT=300
NBX_ENGINE_CONNECT_TIMEOUT=15
NBX_ENGINE_RETRY_TIMES=1
NBX_ENGINE_RETRY_SLEEP_MS=800
NBX_ENGINE_SOURCE_DISCOVERY=true
NBX_LEGACY_CDN_BASE_URL="${CDN_API_BASE_URL}"
NBX_SCHEDULED_SYNC_ENABLED=true
NBX_SCHEDULED_SYNC_EVERY_MINUTES=5
NBX_SCHEDULED_BACKFILL_ENABLED=false
NBX_SCHEDULED_BACKFILL_LIMIT=10
NBX_SCHEDULED_CLEANUP_ENABLED=true

# Bunny Stream
# Keep the API key server-side only. Do not expose it as a NEXT_PUBLIC_* value.
BUNNY_STREAM_ENABLED=false
BUNNY_STREAM_API_BASE_URL=https://video.bunnycdn.com
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_LIBRARY_ID=651140
BUNNY_STREAM_PULL_ZONE_HOSTNAME=vz-e5f45c78-720.b-cdn.net
BUNNY_STREAM_COLLECTION_ID=
BUNNY_STREAM_TIMEOUT=300
BUNNY_STREAM_CONNECT_TIMEOUT=15
BUNNY_STREAM_RETRY_TIMES=1
BUNNY_STREAM_RETRY_SLEEP_MS=800
BUNNY_STREAM_ENABLED_RESOLUTIONS=
BUNNY_STREAM_REFRESH_METADATA_ON_PLAYBACK=false

# Contabo Object Storage
# File uploads use Contabo's S3-compatible endpoint. The REST API values below are only
# for account/product management actions such as listing storages and reading stats.
CONTABO_OBJECT_STORAGE_ENABLED=false
CONTABO_OBJECT_STORAGE_DISK=contabo
CONTABO_OBJECT_STORAGE_ENDPOINT=https://usc1.contabostorage.com
CONTABO_OBJECT_STORAGE_BUCKET=nbx
CONTABO_OBJECT_STORAGE_REGION=US-central
# Optional: leave blank when Contabo API credentials are set; the app can discover these S3 keys.
CONTABO_OBJECT_STORAGE_ACCESS_KEY=
CONTABO_OBJECT_STORAGE_SECRET_KEY=
CONTABO_OBJECT_STORAGE_PUBLIC_URL=https://usc1.contabostorage.com/d052ede4e40a478d92ab1a7ad3f1e435:nbx
CONTABO_OBJECT_STORAGE_PATH_PREFIX=videos
CONTABO_OBJECT_STORAGE_VISIBILITY=public
CONTABO_OBJECT_STORAGE_USE_PATH_STYLE_ENDPOINT=true
CONTABO_OBJECT_STORAGE_CONNECT_TIMEOUT=30
CONTABO_OBJECT_STORAGE_TIMEOUT=21600

CONTABO_API_BASE_URL=https://api.contabo.com
CONTABO_AUTH_URL=https://auth.contabo.com/auth/realms/contabo/protocol/openid-connect/token
CONTABO_API_CLIENT_ID=
CONTABO_API_CLIENT_SECRET=
CONTABO_API_USERNAME=
CONTABO_API_PASSWORD=
# Optional overrides: leave blank to auto-discover via GET /v1/users and GET /v1/object-storages.
CONTABO_API_USER_ID=
CONTABO_API_OBJECT_STORAGE_ID=
CONTABO_API_TIMEOUT=30
CONTABO_API_CONNECT_TIMEOUT=10

# Telebot -> Contabo Object Storage imports
TELEBOT_API_BASE_URL=https://teletyde.nara24fm.com
TELEBOT_WORKER_API_TOKEN=
TELEBOT_CONNECT_TIMEOUT=10
TELEBOT_TIMEOUT=30
TELEBOT_JOB_TIMEOUT=21600
TELEBOT_JOB_POLL_INTERVAL=15
TELEBOT_CAPACITY_RETRY_SECONDS=60
TELEBOT_MAX_ACTIVE_JOBS=2
TELEBOT_MAX_PORTAL_OBJECTS=3
TELEBOT_DESTROY_AFTER_IMPORT=true

# Creator uploads
CREATOR_DIRECT_UPLOAD_MAX_MB=600

# Worker (naraboxtvworker) sync: token for POST /api/v1/worker/sync (same value as worker's PORTAL_API_TOKEN)
PORTAL_WORKER_API_TOKEN=
